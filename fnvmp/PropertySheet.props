<?xml version="1.0" encoding="utf-8"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ImportGroup Label="PropertySheets" />
  <PropertyGroup Label="UserMacros">
    <FalloutNVPath>C:\Games\Fallout New Vegas</FalloutNVPath>
    <ServerOutputPath>C:\Games\Fallout New Vegas\Server</ServerOutputPath>
  </PropertyGroup>
  <PropertyGroup>
    <_PropertySheetDisplayName>FalloutNV.props</_PropertySheetDisplayName>
  </PropertyGroup>
  <ItemDefinitionGroup />
  <ItemGroup>
    <BuildMacro Include="FalloutNVPath">
      <Value>$(FalloutNVPath)</Value>
    </BuildMacro>
  </ItemGroup>
</Project>